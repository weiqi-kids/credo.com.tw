---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---
<Base title="找不到頁面 — 詠業商略顧問有限公司" description="您要找的頁面不存在。">
  <section class="section cta">
    <div class="container">
      <h1>404 找不到頁面</h1>
      <p class="section-sub">您要找的頁面不存在或已搬移。</p>
      <a class="btn" href={base}>回首頁</a>
    </div>
  </section>
</Base>
