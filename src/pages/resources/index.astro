---
import Base from "../../layouts/Base.astro";
import { CATEGORIES, LINE_URL } from "../../lib/site";
import { getCollection } from "astro:content";

const tools = (await getCollection("resources", (r) => !r.data.draft)).sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);
const base = import.meta.env.BASE_URL;
---
<Base
  title="實用工具 — 詠業商略顧問有限公司"
  description="詠業CREDO 錦囊：到職簽署、收到存證信函、被資遣、家人過世、簽租約——每個關鍵時刻的檢查清單、文件範本與行動指南，由律師逐條把關。"
  currentNav="resources"
>
  <section class="section">
    <div class="container">
      <h1 class="section-title">實用工具</h1>
      <p class="section-sub">事情發生的當下，先照著清單做。每一份工具都對應一個關鍵時刻：該簽什麼、該注意什麼、該保存什麼，以及什麼情況該直接找律師。</p>
      <div class="insight-list">
        {tools.map((t) => (
          <a class={`insight-item${t.data.cover ? " has-cover" : ""}`} href={`${base}resources/${t.id}/`}>
            <span class="insight-body">
              <span class="insight-cat">{t.data.moment}</span>
              <span class="insight-title">{t.data.title}</span>
              <span class="insight-date">給{t.data.audience}</span>
              <span class="insight-desc">{t.data.description}</span>
            </span>
            {t.data.cover && <span class="insight-cover-box"><img class="insight-cover" src={`${base}${t.data.cover}`} alt={t.data.coverAlt || t.data.title} loading="lazy" decoding="async" /></span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt cta">
    <div class="container">
      <h2>找不到你需要的工具？</h2>
      <a class="btn" href={LINE_URL} target="_blank" rel="noopener">聯絡我們</a>
    </div>
  </section>
</Base>
