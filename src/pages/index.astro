---
import Base from "../layouts/Base.astro";
import LatestInsights from "../components/LatestInsights.astro";
import { LINE_URL, SCA_URL } from "../lib/site";
const base = import.meta.env.BASE_URL;
---
<Base
  title="詠業商略顧問有限公司"
  description="詠業CREDO專注提供個人及中小企業關於「安全」的解決方案：法務訂閱、資產監護、智財維權與資安策定。"
  preloadImage="images/hero-home.webp"
>
  <section class="hero arrow-divider" style={`background-image:url('${base}images/hero-home.webp')`}>
    <div class="container">
      <h1>獨有的法務訂閱、資產監護、<br />智財維權與資安策定</h1>
      <p class="lead">公司為了「安全」控管，團隊除了執業律師結合ISO27001資訊安全認證夥伴後，在多家上市公司任職法務主管的專業團隊也陸續加入詠業，我們便持續開發法務資料庫系統，讓科技法務走入人群。</p>
      <a class="btn" href={SCA_URL} target="_blank" rel="noopener">SCA退休安心 三寶 專為退休人士設計的退休保障方案！</a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="audience-grid">
        <a class="audience-card" href={`${base}companysafe/`}>
          <img src={`${base}images/card-corporate.webp`} alt="企業安全解決方案" width="1200" height="675" loading="lazy" decoding="async" />
          <span class="label">法人</span>
        </a>
        <a class="audience-card" href={`${base}naturalpersonsafe/`}>
          <img src={`${base}images/card-personal.webp`} alt="個人安全解決方案" width="1200" height="675" loading="lazy" decoding="async" />
          <span class="label">自然人</span>
        </a>
      </div>
    </div>
  </section>

  <section class="hero arrow-divider" style={`background-image:url('${base}images/hero-life.webp')`}>
    <div class="container">
      <div class="duo">
        <div>
          <h2>生活中，法律與您其實<br />息息相關</h2>
          <p class="lead">大家或多或少都曾在「法」的領域吃過虧，不嚴重的-自我療癒，嚴重的-血本無歸。其實認識一個懂法的人總會讓生活比較安心。如果能認識一群了解法律還能細心提醒風險控管的團隊是否更能安枕無憂！詠業CREDO專注提供個人及中小企業關於「安全」的解決方案，我們甚至提供便捷的法務服務流程讓客戶用最少經費解決最大的麻煩。</p>
          <a class="btn" href={`${base}startup/`}>如何啟動服務流程</a>
        </div>
        <div class="art">
          <img src={`${base}images/life-illustration.webp`} alt="詠業服務示意" width="750" height="1000" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h1 class="section-title">合作與實績</h1>
      <p class="section-sub">為什麼您應該相信詠業CREDO商略團隊</p>
      <div class="partner-grid">
        {[1, 2, 3, 4, 5, 6, 7].map((i) => (
          <img src={`${base}images/partner-${i}.webp`} alt="合作夥伴" width="400" height="468" loading="lazy" decoding="async" />
        ))}
      </div>
    </div>
  </section>

  <LatestInsights />

  <section class="section section--alt cta">
    <div class="container">
      <h2>與詠業聯繫</h2>
      <a class="btn" href={LINE_URL} target="_blank" rel="noopener">聯絡我們</a>
    </div>
  </section>
</Base>
