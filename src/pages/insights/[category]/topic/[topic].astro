---
import Base from "../../../../layouts/Base.astro";
import InsightList from "../../../../components/InsightList.astro";
import { CATEGORIES, SERVICES, TOPICS, LINE_URL } from "../../../../lib/site";
import { getCollection } from "astro:content";

// 有文才開門：只為「至少有 1 篇文章」的主題生成頁面（thin content 防線）。
// 主題頁一律掛在該主題所屬的 category 底下；文章本身掛其他 category（如退休保障
// 借用個人資產主題）也會被列進來。
export async function getStaticPaths() {
  const posts = await getCollection("insights");
  const used = [...new Set(posts.map((p) => p.data.topic).filter(Boolean))] as string[];
  return used
    .filter((t) => TOPICS[t])
    .map((t) => ({ params: { category: TOPICS[t].category, topic: t } }));
}

const { topic } = Astro.params;
const t = TOPICS[topic!];
const cat = CATEGORIES[t.category];
const service = SERVICES[t.service];
const posts = await getCollection("insights", (p) => p.data.topic === topic);
const base = import.meta.env.BASE_URL;
---
<Base
  title={`${t.label} — ${cat.label} — 詠業商略顧問有限公司`}
  description={`${t.label}法律實務解析：${t.keywords}。詠業CREDO 律師與法務團隊的專業見解。`}
  currentNav="insights"
>
  <section class="section">
    <div class="container">
      <p class="breadcrumb">
        <a href={base}>首頁</a> › <a href={`${base}insights/`}>法律新知</a> › <a href={`${base}insights/${t.category}/`}>{cat.label}</a> › {t.label}
      </p>
      <h1 class="section-title">{t.label}</h1>
      <p class="section-sub">「{service.label}」服務線的法律課題：{t.keywords}。</p>
      <InsightList posts={posts} />
      <p class="cta"><a class="btn btn--ghost" href={`${base}insights/${t.category}/`}>回 {cat.label}</a></p>
    </div>
  </section>

  <section class="section section--alt cta">
    <div class="container">
      <h2>有{t.label}相關問題想諮詢？</h2>
      <a class="btn" href={LINE_URL} target="_blank" rel="noopener">聯絡我們</a>
    </div>
  </section>
</Base>
