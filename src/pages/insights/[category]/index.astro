---
import Base from "../../../layouts/Base.astro";
import InsightList from "../../../components/InsightList.astro";
import CategoryNav from "../../../components/CategoryNav.astro";
import { CATEGORIES, SERVICES, LINE_URL } from "../../../lib/site";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const cat = CATEGORIES[category!];
const posts = await getCollection("insights", (p) => p.data.category === category);
const base = import.meta.env.BASE_URL;
// 內容骨架：本分類底下的服務 × 主題（docs/content-taxonomy.md）。
// 有文才開門：主題有文章才生成主題頁、卡片才變連結（跨 category 借用的文章也計入）。
const services = Object.entries(SERVICES).filter(([, s]) => s.category === category);
const allPosts = await getCollection("insights");
const topicCount = (key: string) => allPosts.filter((p) => p.data.topic === key).length;
---
<Base
  title={`${cat.label} — 法律新知 — 詠業商略顧問有限公司`}
  description={`${cat.label}實務解析：${cat.description}`}
  currentNav="insights"
>
  <section class="section">
    <div class="container">
      <p class="breadcrumb"><a href={base}>首頁</a> › <a href={`${base}insights/`}>法律新知</a> › {cat.label}</p>
      <h1 class="section-title">{cat.label}</h1>
      <p class="section-sub">{cat.description}</p>
      {cat.cta && (
        <p class="cta">
          <a
            class="btn"
            href={cat.cta.external ? cat.cta.href : `${base}${cat.cta.href.replace(/^\//, "")}`}
            target={cat.cta.external ? "_blank" : undefined}
            rel={cat.cta.external ? "noopener" : undefined}
          >{cat.cta.label}</a>
        </p>
      )}
      <CategoryNav current={category} />
      <InsightList posts={posts} />

      {services.length > 0 && (
        <div class="topic-map">
          <h2 class="section-title">主題總覽</h2>
          {services.map(([, s]) => (
            <section class="topic-service">
              <h3>{s.label}</h3>
              <ul>
                {Object.entries(s.topics).map(([key, t]) =>
                  topicCount(key) > 0 ? (
                    <li class="has-articles">
                      <a href={`${base}insights/${category}/topic/${key}/`}>
                        <strong>{t.label}<em>{topicCount(key)} 篇 ›</em></strong>
                        <span>{t.keywords}</span>
                      </a>
                    </li>
                  ) : (
                    <li>
                      <strong>{t.label}</strong>
                      <span>{t.keywords}</span>
                    </li>
                  )
                )}
              </ul>
            </section>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="section section--alt cta">
    <div class="container">
      <h2>有法律問題想諮詢？</h2>
      <a class="btn" href={LINE_URL} target="_blank" rel="noopener">聯絡我們</a>
    </div>
  </section>
</Base>
