---
import { CATEGORIES } from "../lib/site";
import { sortForList, postPath, type Post } from "../lib/content";

interface Props {
  posts: Post[];
}
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL;
const sorted = sortForList(posts);
---
{sorted.length === 0 ? (
  <p class="section-sub">文章籌備中，敬請期待。</p>
) : (
  <div class="insight-list">
    {sorted.map((p) => (
      <a class="insight-item" href={`${base}${postPath(p)}`}>
        <span class="insight-cat">
          {CATEGORIES[p.data.category].label}
          {p.data.kind === "pillar" && <span class="badge-pillar">必讀</span>}
        </span>
        <span class="insight-title">{p.data.title}</span>
        <span class="insight-date">{p.data.date}</span>
        <span class="insight-desc">{p.data.description}</span>
      </a>
    ))}
  </div>
)}
