---
import { CATEGORIES } from "../lib/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"insights">[];
}
const { posts } = Astro.props;
const base = import.meta.env.BASE_URL;
const sorted = [...posts].sort((a, b) => b.data.date.localeCompare(a.data.date));
---
{sorted.length === 0 ? (
  <p class="section-sub">文章籌備中，敬請期待。</p>
) : (
  <div class="insight-list">
    {sorted.map((p) => (
      <a class="insight-item" href={`${base}insights/${p.data.category}/${p.id}/`}>
        <span class="insight-cat">{CATEGORIES[p.data.category].label}</span>
        <span class="insight-title">{p.data.title}</span>
        <span class="insight-date">{p.data.date}</span>
        <span class="insight-desc">{p.data.description}</span>
      </a>
    ))}
  </div>
)}
