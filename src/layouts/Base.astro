---
import "../styles/global.css";
import FloatingLine from "../components/FloatingLine.astro";
import { SITE_NAME, COPYRIGHT, LINE_URL, CATEGORIES, orgSchema } from "../lib/site";

interface Props {
  title: string;
  description: string;
  schemas?: object[];
  currentNav?: string; // 對應 nav key：companysafe / naturalpersonsafe / startup / insights
  preloadImage?: string; // LCP 圖（CSS background 瀏覽器發現得晚，需 preload），相對 base 路徑如 "images/hero-home.webp"
  ogImage?: string; // 分享縮圖，相對 base 路徑（如 images/covers/x.webp）；未給用 logo
}
const { title, description, schemas = [], currentNav, preloadImage, ogImage } = Astro.props;

const base = import.meta.env.BASE_URL; // 含尾斜線
const canonical = new URL(Astro.url.pathname, Astro.site);
const NAV = [
  { key: "companysafe", href: `${base}companysafe/`, label: "企業安全" },
  { key: "naturalpersonsafe", href: `${base}naturalpersonsafe/`, label: "個人安全" },
  { key: "startup", href: `${base}startup/`, label: "服務流程" },
  { key: "insights", href: `${base}insights/`, label: "法律新知" },
  { key: "resources", href: `${base}resources/`, label: "實用工具" },
];
---
<!DOCTYPE html>
<html lang="zh-Hant-TW">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" href={`${base}images/logo.png`} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={new URL(`${base}${ogImage || "images/logo.png"}`, Astro.site)} />
<link rel="sitemap" href={`${base}sitemap-index.xml`} />
{preloadImage && <link rel="preload" as="image" href={`${base}${preloadImage}`} fetchpriority="high" />}
{[orgSchema(), ...schemas].map((s) => (
  <script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
</head>
<body>
<a class="skip-link" href="#main">跳至主要內容</a>

<header class="site-header">
  <div class="container">
    <a class="site-logo" href={base}><img src={`${base}images/logo.png`} alt={SITE_NAME} /></a>
    <nav class="site-nav" aria-label="主選單">
      {NAV.map((n) => (
        <a href={n.href} aria-current={currentNav === n.key ? "page" : undefined}>{n.label}</a>
      ))}
    </nav>
  </div>
</header>

<main id="main">
  <slot />
</main>

<footer class="site-footer">
  <div class="container footer-nav">
    <nav aria-label="服務方案">
      <h2>服務方案</h2>
      <a href={`${base}companysafe/`}>企業安全</a>
      <a href={`${base}naturalpersonsafe/`}>個人安全</a>
      <a href={`${base}startup/`}>服務流程</a>
    </nav>
    <nav aria-label="法律新知">
      <h2>法律新知</h2>
      {Object.entries(CATEGORIES).map(([key, c]) => (
        <a href={`${base}insights/${key}/`}>{c.label}</a>
      ))}
      <a href={`${base}resources/`}>實用工具</a>
    </nav>
    <nav aria-label="聯絡">
      <h2>聯絡詠業</h2>
      <a href={LINE_URL} target="_blank" rel="noopener">LINE 官方帳號</a>
      <a href={base}>回首頁</a>
    </nav>
  </div>
  <p class="footer-copy">{COPYRIGHT}</p>
</footer>
<FloatingLine />
</body>
</html>
